# ─── Anthropic Claude API ───────────────────────────────────────────────
# Used by the chatbot to answer questions and qualify leads.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model to use. Haiku is cheapest (~$0.25/M input tokens), Sonnet is smarter.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Per-conversation token cap (safety net so a long convo can't run up a bill)
CHAT_MAX_TOKENS=600

# ─── Monday.com lead capture ────────────────────────────────────────────
# Create an API token in Monday → avatar → Developers → My Access Tokens
MONDAY_API_TOKEN=eyJhbGciOiJ...
# Find the board ID in the URL of the leads board: /boards/<this-number>
MONDAY_BOARD_ID=1234567890
# Optional: a specific group ID inside the board (defaults to "topics")
MONDAY_GROUP_ID=topics

# ─── Google Sheets lead log (optional but recommended) ──────────────────
# Service-account email + private key from a Google Cloud service-account JSON.
# Share the target sheet with this email (Editor access).
GOOGLE_SERVICE_ACCOUNT_EMAIL=alvy-leads@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_SHEET_TAB=Leads

# ─── Notifications (optional) ───────────────────────────────────────────
# Email to send the lead-summary report to
LEAD_NOTIFY_EMAIL=jose@alvycolorchanges.com
# Webhook URL the daily digest POSTs to (Zapier/Make/Resend webhook URL).
# The webhook receives { to, subject, html, text } and forwards as email.
DIGEST_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/xxxx/

# ─── Auto-update agent (used by GitHub Actions) ─────────────────────────
# Personal access token with `repo` scope so the agent can open PRs
GH_AGENT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
